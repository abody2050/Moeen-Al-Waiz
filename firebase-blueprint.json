{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about the preacher using the app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The preacher's display name." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "idNumber": { "type": "string", "description": "A custom 5-digit ID generated for the user." },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "fontStyle": { "type": "string", "enum": ["lateef", "amiri", "tajawal", "cairo", "vazir", "scheherazade"] },
            "fontSize": { "type": "integer" },
            "lineHeight": { "type": "number" },
            "isDarkMode": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "displayName"]
    },
    "Sermon": {
      "title": "Sermon",
      "description": "A generated sermon, lesson, or reflection.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Reference to the User's uid." },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["sermon", "exhortation", "lesson", "reflection", "story"] },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "duration": { "type": "integer", "description": "Approximate duration in minutes." },
        "instructions": { "type": "string", "description": "User instructions used for generation." }
      },
      "required": ["userId", "title", "content", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Preacher profiles and settings."
    },
    "/sermons/{sermonId}": {
      "schema": "Sermon",
      "description": "Stored sermons generated by the user."
    }
  }
}
